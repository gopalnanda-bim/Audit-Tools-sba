<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Category Parameter Auditor"
        Height="900" Width="1400"
        WindowStartupLocation="CenterScreen"
        Background="#FFF7F7F7">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Section A -->
            <GroupBox Header="Scope &amp; Category" Padding="12" Grid.Row="0" Margin="0,0,0,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="360"/>
                        <ColumnDefinition Width="220"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Scope -->
                    <StackPanel Orientation="Horizontal" Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" VerticalAlignment="Center" Margin="0,0,12,0">
                        <RadioButton x:Name="ActiveViewRadio" Content="Active View" IsChecked="True" Margin="0,0,12,0"/>
                        <RadioButton x:Name="WholeModelRadio" Content="Whole Model"/>
                    </StackPanel>

                    <!-- Category -->
                    <TextBlock Text="Category:" Grid.Row="0" Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,6,0"/>
                    <ComboBox x:Name="CategoryCombo" Grid.Row="0" Grid.Column="3" Width="320" IsEditable="False" DisplayMemberPath="Name" />

                    <!-- Buttons -->
                    <StackPanel Orientation="Horizontal" Grid.Row="0" Grid.Column="4" HorizontalAlignment="Right">
                        <Button x:Name="LoadElementsButton" Content="Load Elements" Width="110" Margin="0,0,6,0"/>
                        <Button x:Name="RefreshButton" Content="Refresh" Width="80"/>
                    </StackPanel>

                    <!-- Search Category -->
                    <TextBlock Text="Search category:" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,6,0" />
                    <TextBox x:Name="CategorySearchBox" Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="4" MinWidth="400" />

                    <!-- Family filter -->
                    <TextBlock Text="Family filter:" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,6,0" />
                    <ComboBox x:Name="FamilyFilterCombo" Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="4" MinWidth="400" MaxDropDownHeight="400" HorizontalAlignment="Stretch" />

                    <!-- Type filter -->
                    <TextBlock Text="Type filter:" Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,6,0" />
                    <ComboBox x:Name="TypeFilterCombo" Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="4" MinWidth="400" MaxDropDownHeight="400" HorizontalAlignment="Stretch" />

                </Grid>
            </GroupBox>

            <!-- Section B -->
            <GroupBox Header="Parameters" Padding="12" Grid.Row="1" Margin="0,0,0,12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="200"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" Margin="0,0,10,6">
                        <TextBlock Text="Search:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBox x:Name="SearchBox" Width="200"/>
                    </StackPanel>

                    <ListBox x:Name="ParameterList" Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                             Height="140" />

                    <StackPanel Grid.Row="2" Grid.Column="0" Orientation="Horizontal" Margin="0,8,0,0">
                        <CheckBox x:Name="FailMissingCheck" Content="Fail on Missing" IsChecked="True" Margin="0,0,12,0"/>
                        <CheckBox x:Name="FailEmptyCheck" Content="Fail on Empty" IsChecked="True"/>
                    </StackPanel>

                    <Button x:Name="AuditButton" Grid.Row="2" Grid.Column="1" Content="Audit Selected Parameter"
                            HorizontalAlignment="Right" Width="180" Margin="0,8,0,0"/>
                </Grid>
            </GroupBox>

            <!-- Section C -->
            <GroupBox Header="Results" Padding="12" Grid.Row="2">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <DataGrid x:Name="ResultsGrid"
                              Grid.Row="0"
                              AutoGenerateColumns="False"
                              HeadersVisibility="Column"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                              ScrollViewer.HorizontalScrollBarVisibility="Auto"
                              MinHeight="320"
                              Margin="0,0,0,6"
                              SelectionMode="Single"
                              SelectionUnit="FullRow">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ElementId" Binding="{Binding [ElementId]}" Width="80"/>
                            <DataGridTextColumn Header="Category" Binding="{Binding [Category]}" Width="150"/>
                            <DataGridTextColumn Header="Family" Binding="{Binding [Family]}" Width="180"/>
                            <DataGridTextColumn Header="Type" Binding="{Binding [Type]}" Width="180"/>
                            <DataGridTextColumn Header="CurrentValue" Binding="{Binding [CurrentValue]}" Width="220"/>
                            <DataGridTextColumn Header="FailReason" Binding="{Binding [FailReason]}" Width="140"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                        <Button x:Name="SelectAllButton" Content="Select All Failures" Width="130" Margin="0,0,6,0"/>
                        <Button x:Name="IsolateButton" Content="Isolate Failures" Width="120" Margin="0,0,6,0"/>
                        <Button x:Name="ExportButton" Content="Export CSV" Width="100" Margin="0,0,6,0"/>
                        <Button x:Name="ClearButton" Content="Clear Results" Width="110"/>
                    </StackPanel>
                    <TextBlock x:Name="StatusText" Grid.Row="2" Grid.Column="0"
                               Margin="0,10,0,0" Foreground="#333" FontSize="15" FontWeight="Bold"
                               Text="Ready" />
                </Grid>
            </GroupBox>
        </Grid>
    </ScrollViewer>
</Window>
